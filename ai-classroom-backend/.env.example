# ============================================================================
# DJANGO CONFIGURATION
# ============================================================================

# Secret key for Django (MUST be set for production!)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=dev-secret-key

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (NEVER true in production!)
DEBUG=true

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=127.0.0.1,localhost

# ============================================================================
# GROQ & SARVAM CONFIGURATION
# ============================================================================

# Groq API key (required for AI chat)
GROQ_API_KEY=

# Groq models
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_CODER=llama-3.3-70b-versatile
GROQ_CHAT_MAX_TOKENS=800
GROQ_EMBED_MODEL=
GROQ_EMBED_BASE_URL=https://api.groq.com/openai/v1

# Sarvam API key (required for voice + translation)
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_STT_MODE=
SARVAM_STT_LANGUAGE_CODE=unknown
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_OUTPUT_CODEC=wav

# ============================================================================
# OLLAMA EMBEDDING FALLBACK (Optional)
# ============================================================================

# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# Model for embeddings (leave empty to use sentence-transformers)
OLLAMA_EMBED_MODEL=

# Keep-alive time for embeddings model
OLLAMA_EMBED_KEEP_ALIVE=30m

# Timeout for Ollama requests (seconds)
OLLAMA_TIMEOUT=300

# ============================================================================
# CACHING & REDIS
# ============================================================================

# Redis URL for caching (optional, falls back to in-memory cache)
REDIS_URL=redis://localhost:6379/0

# Cache timeout for general queries (seconds)
CACHE_TIMEOUT=300

# Cache timeout for answers (seconds)
ANSWER_CACHE_TIMEOUT=300

# Cache timeout for search results (seconds)
SEARCH_CACHE_TIMEOUT=1800

# ============================================================================
# SECURITY & SSL
# ============================================================================

# Redirect HTTP to HTTPS (set to true in production)
SECURE_SSL_REDIRECT=false

# Secure session cookies (set to true in production with HTTPS)
SESSION_COOKIE_SECURE=false

# Secure CSRF cookies (set to true in production with HTTPS)
CSRF_COOKIE_SECURE=false

# HSTS max age in seconds (set in production)
SECURE_HSTS_SECONDS=0

# HSTS preload
SECURE_HSTS_PRELOAD=false

# ============================================================================
# INSTITUTE CONFIGURATION
# ============================================================================

# Institute email domain for user emails
INSTITUTE_EMAIL_DOMAIN=iiitdwd.ac.in

# ============================================================================
# ERROR TRACKING (Optional)
# ============================================================================

# Sentry DSN for error tracking (optional)
SENTRY_DSN=
